{
  "manifest_version": 3,
  "name": "Rahbarlik AI platformasi",
  "version": "2.2.1",
  "description": "claude.ai uchun rahbarlik boshqaruv oynasi — Bitrix24 jonli tahlil (HARIDLAR.UZ).",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://ai-executive-platform.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rahbarlik AI sozlamalari"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "js/constants.js",
        "js/migrate.js",
        "js/secret-storage.js",
        "js/response-mode.js",
        "js/messaging.js",
        "js/config.js",
        "js/icons.js",
        "js/errors.js",
        "js/history-db.js",
        "js/state.js",
        "js/markdown.js",
        "js/charts.js",
        "js/tables.js",
        "js/timeline.js",
        "js/report-cards.js",
        "js/export.js",
        "js/loading.js",
        "js/upload.js",
        "js/status-bar.js",
        "js/response-mode.js",
        "js/panel-control.js",
        "js/dashboard.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/logo.svg"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}
