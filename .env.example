# ── Application ──────────────────────────────────────────────
APP_NAME=Bitrix24 Claude Integration
APP_ENV=production
# DEBUG accepts: true/false, 1/0, yes/no (quoted or unquoted)
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Public / Connector (Render production) ───────────────────
PUBLIC_BASE_URL=https://your-render-domain.onrender.com
CONNECTOR_SECRET=change-me-to-a-long-random-secret

# ── Bitrix24 ─────────────────────────────────────────────────
# Incoming webhook URL (Applications → Webhooks → Incoming webhook)
# Example: https://your-domain.bitrix24.com/rest/1/xxxxxxxxxx/
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.uz/rest/1/your-webhook-token/

# ── Anthropic Claude ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ── Telegram (optional — omit both variables to disable) ─────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Scheduler (daily report) ─────────────────────────────────
# DAILY_REPORT_ENABLED accepts: true/false, 1/0, yes/no
DAILY_REPORT_ENABLED=false
DAILY_REPORT_HOUR=9
DAILY_REPORT_MINUTE=0
DAILY_REPORT_TIMEZONE=Asia/Tashkent
DAILY_REPORT_AGENT=ceo

# ── Bitrix24 fetch limits ────────────────────────────────────
BITRIX_LEADS_LIMIT=50
BITRIX_DEALS_LIMIT=50
BITRIX_CONTACTS_LIMIT=50
BITRIX_TASKS_LIMIT=50
